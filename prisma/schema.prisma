generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Board {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  items     Item[]
}

model Item {
  id        String   @id @default(uuid())
  type      String   // 'TEXT', 'IMAGE', 'QUOTE'
  content   String?
  x         Float
  y         Float
  width     Float
  height    Float
  zIndex    Int      @default(0)
  color     String?
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id])
}
